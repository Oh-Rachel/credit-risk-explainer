# --- Data ---
# Raw data is excluded: it's large, redistributable-but-not-ours (Kaggle ToS),
# and reproducible by anyone who downloads it (see README for the link).
data/raw/

# Processed data is derived from the raw Kaggle data (same ToS/redistribution
# reasoning) and is fully reproducible by running 01-02 in notebooks/.
data/processed/

# --- Models ---
# Trained model artifacts and the chosen threshold are regenerable by running
# 03_modeling.ipynb and 04_threshold_tuning.ipynb — not committed as binaries.
models/

# --- Python ---
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/
.venv/
venv/
env/
*.egg-info/

# --- Secrets / config ---
.env
.env.*

# --- Personal / assistant notes (not shared project docs) ---
CLAUDE.md

